<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.monitoring.hourly</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/vishwajeetagrawal/productivity-tools/monitoring/monitor.py</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <array>
        <!-- Run every hour at the top of the hour -->
        <dict>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>
    
    <key>StandardOutPath</key>
    <string>/tmp/monitoring.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/monitoring.error.log</string>
    
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>