#!/bin/bash

# Function to remove timer by title
remove_timer() {
  local search_title="$1"
  
  if [ -z "$search_title" ]; then
    echo "Error: Please provide a title to remove"
    echo "Usage: $0 --remove <title>"
    exit 1
  fi
  
  # Find matching timers
  local matching_pids=()
  local matching_titles=()
  local temp_file="/tmp/timer_matches_$$"
  > "$temp_file"
  
  # Find all sleep processes
  ps aux | grep -E "sleep [0-9]+" | grep -v grep | while read -r line; do
    pid=$(echo "$line" | awk '{print $2}')
    sleep_time=$(echo "$line" | awk '{print $NF}')
    
    # Try to find title from recent logs
    title="Timer"
    log_file="$HOME/.local/backend/timers.txt"
    if [ -f "$log_file" ]; then
      matching_title=$(grep "($sleep_time seconds)" "$log_file" | tail -1 | sed -n 's/.*title: "\([^"]*\)".*/\1/p')
      if [ -n "$matching_title" ]; then
        title="$matching_title"
      fi
    fi
    
    # Check if title matches (case-insensitive partial match)
    if [[ "${title,,}" == *"${search_title,,}"* ]]; then
      echo "$pid|$title" >> "$temp_file"
    fi
  done
  
  # Read matches
  local count=0
  while IFS='|' read -r pid title; do
    matching_pids+=("$pid")
    matching_titles+=("$title")
    ((count++))
  done < "$temp_file"
  rm -f "$temp_file"
  
  # Handle results
  if [ $count -eq 0 ]; then
    echo "No timers found with title containing: $search_title"
    exit 0
  elif [ $count -eq 1 ]; then
    # Single match - remove it
    echo "Removing timer: ${matching_titles[0]} (PID: ${matching_pids[0]})"
    kill "${matching_pids[0]}" 2>/dev/null
    if [ $? -eq 0 ]; then
      echo "Timer removed successfully"
    else
      echo "Error: Could not remove timer"
      exit 1
    fi
  else
    # Multiple matches - prompt user
    echo "Multiple timers found matching '$search_title':"
    echo
    for i in "${!matching_pids[@]}"; do
      echo "  $((i+1)). ${matching_titles[$i]} (PID: ${matching_pids[$i]})"
    done
    echo
    read -p "Enter the number of the timer to remove (1-$count, or 'q' to quit): " choice
    
    if [ "$choice" = "q" ]; then
      echo "Cancelled"
      exit 0
    fi
    
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le $count ]; then
      idx=$((choice-1))
      echo "Removing timer: ${matching_titles[$idx]} (PID: ${matching_pids[$idx]})"
      kill "${matching_pids[$idx]}" 2>/dev/null
      if [ $? -eq 0 ]; then
        echo "Timer removed successfully"
      else
        echo "Error: Could not remove timer"
        exit 1
      fi
    else
      echo "Invalid choice"
      exit 1
    fi
  fi
}

# Function to show running timers
show_timers() {
  echo "Running timers:"
  
  # Check if there are any running timers
  if ! ps aux | grep -E "sleep [0-9]+" | grep -v grep > /dev/null; then
    echo "  No timers running"
  else
    # Print table header
    printf "%-8s %-30s %-10s %-10s\n" "PID" "Title" "Total" "Remaining"
    printf "%-8s %-30s %-10s %-10s\n" "--------" "------------------------------" "----------" "----------"
    
    # Store PIDs and their info temporarily
    temp_file="/tmp/timer_info_$$"
    > "$temp_file"
    
    # Find all sleep processes
    ps aux | grep -E "sleep [0-9]+" | grep -v grep | while read -r line; do
      pid=$(echo "$line" | awk '{print $2}')
      sleep_time=$(echo "$line" | awk '{print $NF}')
      
      # Try to find parent process to verify it's from timer.sh
      if ps -p "$pid" > /dev/null 2>&1; then
        # Get elapsed time using ps
        elapsed=$(ps -o etime= -p "$pid" | xargs)
        # Convert elapsed time to seconds
        if [[ "$elapsed" =~ ^([0-9]+):([0-9]+)$ ]]; then
          # MM:SS format
          elapsed_sec=$((${BASH_REMATCH[1]} * 60 + ${BASH_REMATCH[2]}))
        elif [[ "$elapsed" =~ ^([0-9]+):([0-9]+):([0-9]+)$ ]]; then
          # HH:MM:SS format
          elapsed_sec=$((${BASH_REMATCH[1]} * 3600 + ${BASH_REMATCH[2]} * 60 + ${BASH_REMATCH[3]}))
        else
          elapsed_sec=0
        fi
        
        # Calculate remaining time
        remaining=$((sleep_time - elapsed_sec))
        if [ $remaining -lt 0 ]; then
          remaining=0
        fi
        
        # Format total time
        total_hours=$((sleep_time / 3600))
        total_minutes=$(((sleep_time % 3600) / 60))
        total_seconds=$((sleep_time % 60))
        
        total_str=""
        if [ $total_hours -gt 0 ]; then
          total_str="${total_hours}h"
        fi
        if [ $total_minutes -gt 0 ]; then
          total_str="${total_str}${total_minutes}m"
        fi
        total_str="${total_str}${total_seconds}s"
        
        # Format remaining time
        rem_hours=$((remaining / 3600))
        rem_minutes=$(((remaining % 3600) / 60))
        rem_seconds=$((remaining % 60))
        
        rem_str=""
        if [ $rem_hours -gt 0 ]; then
          rem_str="${rem_hours}h"
        fi
        if [ $rem_minutes -gt 0 ]; then
          rem_str="${rem_str}${rem_minutes}m"
        fi
        rem_str="${rem_str}${rem_seconds}s"
        
        echo "$pid|$sleep_time|$total_str|$rem_str" >> "$temp_file"
      fi
    done
    
    # Try to match PIDs with titles from log file
    log_file="$HOME/.local/backend/timers.txt"
    while IFS='|' read -r pid sleep_time total_str rem_str; do
      title="Timer"
      # Try to find title from recent logs
      if [ -f "$log_file" ]; then
        # Look for a log entry with matching duration
        matching_title=$(grep "($sleep_time seconds)" "$log_file" | tail -1 | sed -n 's/.*title: "\([^"]*\)".*/\1/p')
        if [ -n "$matching_title" ]; then
          title="$matching_title"
        fi
      fi
      
      # Truncate title if too long
      if [ ${#title} -gt 30 ]; then
        title="${title:0:27}..."
      fi
      
      printf "%-8s %-30s %-10s %-10s\n" "$pid" "$title" "$total_str" "$rem_str"
    done < "$temp_file"
    
    rm -f "$temp_file"
  fi
  
  echo -e "\nRecent timer history:"
  log_file="$HOME/.local/backend/timers.txt"
  if [ -f "$log_file" ]; then
    # Print table header
    printf "%-25s %-10s %-30s\n" "Timestamp" "Duration" "Title"
    printf "%-25s %-10s %-30s\n" "-------------------------" "----------" "------------------------------"
    
    # Parse and format the log entries (last 10, most recent first)
    tail -10 "$log_file" | tac | while IFS= read -r line; do
      # Extract timestamp (everything before "Timer set")
      timestamp=$(echo "$line" | sed 's/: Timer set.*//')
      
      # Extract duration (e.g., "5m")
      duration=$(echo "$line" | sed -n 's/.*Timer set for \([^ ]*\).*/\1/p')
      
      # Extract title
      title=$(echo "$line" | sed -n 's/.*title: "\([^"]*\)".*/\1/p')
      
      # Truncate title if too long
      if [ ${#title} -gt 30 ]; then
        title="${title:0:27}..."
      fi
      
      # Format timestamp to be shorter
      short_timestamp=$(echo "$timestamp" | sed 's/  */ /g' | cut -d' ' -f2-5)
      
      printf "%-25s %-10s %-30s\n" "$short_timestamp" "$duration" "$title"
    done
  else
    echo "No timer history found at $log_file"
  fi
}

# Check if --show flag is passed
if [ "$1" = "--show" ]; then
  show_timers
  exit 0
fi

# Check if --cancel flag is passed (cancel by PID)
if [ "$1" = "--cancel" ]; then
  shift
  if [ -z "$1" ]; then
    echo "Error: Please provide a PID to cancel"
    echo "Usage: $0 --cancel <PID>"
    exit 1
  fi
  
  pid="$1"
  # Check if PID is a number
  if ! [[ "$pid" =~ ^[0-9]+$ ]]; then
    echo "Error: PID must be a number"
    exit 1
  fi
  
  # Check if process exists and is a timer (sleep process)
  if ps -p "$pid" | grep -q "sleep"; then
    kill "$pid" 2>/dev/null
    if [ $? -eq 0 ]; then
      echo "Timer with PID $pid cancelled successfully"
    else
      echo "Error: Could not cancel timer with PID $pid"
      exit 1
    fi
  else
    echo "Error: No timer found with PID $pid"
    exit 1
  fi
  exit 0
fi

# Check if --remove flag is passed
if [ "$1" = "--remove" ]; then
  shift
  remove_timer "$@"
  exit 0
fi

if [ $# -lt 1 ]; then
  echo "Usage: $0 <time> [title...] OR $0 [title...] <time>"
  echo "       $0 --show  (to show running timers)"
  echo "       $0 --cancel <PID>  (to cancel a timer by PID)"
  echo "       $0 --remove <title>  (to remove a timer by title)"
  echo "Time format: e.g., 5m for 5 minutes, 30s for 30 seconds, 2h for 2 hours."
  exit 1
fi

# Function to check if a string is a valid time format
is_time_format() {
  [[ "$1" =~ ^[0-9]+[smh]$ ]]
}

# Determine if time is first or last argument
if is_time_format "$1"; then
  # Time is first argument (current format)
  time_input="$1"
  shift
  title="${*:-Timer}"  # Default to "Timer" if no title provided
elif is_time_format "${!#}"; then
  # Time is last argument (new format)
  time_input="${!#}"
  # Get all arguments except the last one as title
  title=""
  arg_count=$#
  for ((i=1; i<arg_count; i++)); do
    if [ -z "$title" ]; then
      title="${!i}"
    else
      title="$title ${!i}"
    fi
  done
  title="${title:-Timer}"  # Default to "Timer" if no title provided
else
  echo "Error: No valid time format found in arguments."
  echo "Time must be in format like 5m, 30s, 2h"
  exit 1
fi

# Parse time
num="${time_input%[a-z]}"
unit="${time_input##*[0-9]}"

# Check if num is empty or not a number
if [ -z "$num" ] || ! [[ "$num" =~ ^[0-9]+$ ]]; then
  echo "Invalid time format. Use format like 5m, 30s, 2h"
  exit 1
fi

case "$unit" in
  s) sec="$num" ;;
  m) sec=$((num * 60)) ;;
  h) sec=$((num * 3600)) ;;
  *) echo "Invalid time unit. Use s, m, or h."; exit 1 ;;
esac

# Log to timers.txt
log_dir="$HOME/.local/backend"
log_file="$log_dir/timers.txt"
# Create directory if it doesn't exist
mkdir -p "$log_dir"
echo "$(date): Timer set for $time_input ($sec seconds), title: \"$title\"" >> "$log_file"

# Run sleep and notification in background
(
  sleep "$sec"
  osascript -e "display notification \"\" with title \"$title\" sound name \"default\""
) &

echo "Timer set for $time_input"
